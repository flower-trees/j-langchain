{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"],
      "env": {
        "NODE_ENV": "test"
      }
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": {
        "NODE_ENV": "test"
      }
    },
    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "postgresql://postgres:123456@localhost:5432/postgres"],
      "env": {
        "POSTGRES_URL": "${POSTGRES_URL:postgresql://postgres:123456@localhost:5432/postgres}"
      }
    },
    "cognee": {
      "command": "uv",
      "args": [
        "--directory",
        "/Users/chuanzhizhu/Documents/tools/cognee/cognee-mcp",
        "run",
        "cognee-mcp"
      ]
    }
  }
}